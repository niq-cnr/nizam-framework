+      "acceptance_test": "DELIVERABLE CONFINEMENT: the non-.agent changes across the branch (base 964fe48..HEAD) are exactly the three contracted files.",
+      "command": "set -e\nchanged=$(git diff --name-only 964fe48..HEAD | grep -v '^\\.agent/' | LC_ALL=C sort | tr '\\n' ' ')\ntest \"$changed\" = 'CHANGELOG.md docs/planning/DEBT.md ecosystem/07_progress_comparison.md '\necho 'E07 PASS: non-.agent changes across the branch (dot-anchored filter) are exactly the 3 deliverable files'"
+    },
+    {
+      "acceptance_test": "DOCS/DEBT SYNCED: ecosystem/07 0.2.0 with a matching change_log (NDS Sec 7); DEBT 0.26.0 has NDEBT-022 in Resolved (not Open); CHANGELOG [Unreleased] names the F-057 entry.",
+      "command": "set -e\ngrep -Fq 'version: 0.2.0' ecosystem/07_progress_comparison.md\ngrep -Fq 'Feature 057 (NDEBT-022)' ecosystem/07_progress_comparison.md\ngrep -Fq 'version: 0.26.0' docs/planning/DEBT.md\npython3 - <<'PY'\nimport re\nsect=None; resolved=set(); openset=set()\nfor l in open('docs/planning/DEBT.md'):\n    if l.startswith('## Open'): sect='open'\n    elif l.startswith('## Resolved'): sect='resolved'\n    m=re.match(r'\\| (NDEBT-\\d+) ', l)\n    if m and sect=='resolved': resolved.add(m.group(1))\n    if m and sect=='open': openset.add(m.group(1))\nassert 'NDEBT-022' in resolved and 'NDEBT-022' not in openset, 'NDEBT-022 not Resolved'\nprint('debt ok')\nPY\nsed -n '/## \\[Unreleased\\]/,/## \\[0.7.0\\]/p' CHANGELOG.md | grep -Fq 'Progress-comparison taxonomy completion'\necho 'E08 PASS: ecosystem/07 0.2.0 (change_log synced); DEBT 0.26.0 (NDEBT-022 Resolved); CHANGELOG names F-057'"
+    },
+    {
