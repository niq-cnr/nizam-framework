+      "command": "set -e\npython3 - <<'PY'\nimport json\nimport jsonschema\ntpl = json.load(open('templates/work-packet.template.json'))\nschema = json.load(open('schema/work-packet.schema.json'))\njsonschema.validate(tpl, schema)\nfor f in ('tier', 'blast_radius', 'merge_order'):\n    assert f not in tpl, f + ' should be omitted, not shipped as a literal default'\nPY\necho 'E02 PASS: template validates end-to-end; the three optional enum/integer dispatch fields are omitted (not shipped as literal defaults)'"
