+      "command": "set -e\npython3 - <<'PY'\nimport json, sys\nimport jsonschema\nschema = json.load(open('schema/work-packet.schema.json'))\ntpl = json.load(open('templates/work-packet.template.json'))\njsonschema.validate(tpl, schema)          # real template MUST validate\ntpl['tier'] = '{{TIER}}'                   # restore a placeholder -> MUST fail\ntry:\n    jsonschema.validate(tpl, schema); print('VACUITY: broken template still validated'); sys.exit(1)\nexcept jsonschema.ValidationError:\n    pass\nsys.exit(0)\nPY\necho 'E03 PASS: real template validates; a placeholder-restored (in-memory) copy FAILS jsonschema -- the guard is load-bearing'"
