+sys.exit(0)
+PY
+echo 'E01 PASS: at phase base 15a30e1 the template held {{TIER}} and did NOT validate; no F-054 guard (anti-vacuity)'
+# --- output ---
+E01 PASS: at phase base 15a30e1 the template held {{TIER}} and did NOT validate; no F-054 guard (anti-vacuity)
+[exit 0]
