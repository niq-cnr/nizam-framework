+  echo "OK   primitive   vlib_workflows_sha_pinned (tag fail / sha+local pass / real-tree pass)"
+else
+  echo "FAIL primitive   vlib_workflows_sha_pinned: a scratch or real-tree assertion did not hold"
+  fail=1
+fi
